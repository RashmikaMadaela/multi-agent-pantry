# ── Google API ─────────────────────────────────────────────────────────────
# Never commit a real key. Copy this file to .env and fill in your key.
# The .env file is listed in .gitignore and will never be committed.
GOOGLE_API_KEY=

# ── Model selection ─────────────────────────────────────────────────────────
# Swap to a different model if you hit a 429 quota error on the current one.
# Options: gemini-2.0-flash | gemini-2.0-flash-lite | gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash-lite

# ── Gmail SMTP (for one-click email sending) ────────────────────────────────
# Setup: Google Account → Security → 2-Step Verification → App Passwords
# Create an App Password named "Pantry App" and paste the 16-char token below.
# This is completely FREE — no paid service needed.
GMAIL_SENDER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
