# Secrets — MUST never enter the Docker build context
.env
*.env

# Virtual environment — dependencies are installed fresh in the image
.venv/
venv/
env/

# Runtime output — mounted as a volume instead
output/

# Python cache
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Tests — not needed in the production image
tests/
.pytest_cache/

# Dev tooling
.secrets.baseline
Makefile
*.md
spec.md

# Version control
.git/
.gitignore
